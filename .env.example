# Server Configuration
PORT=3001
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/bring-trust-rating
MONGODB_TEST_URI=mongodb://localhost:27017/bring-trust-rating-test

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=24h

# Trust Score Configuration
TRUST_SCORE_INITIAL=50
TRUST_SCORE_MIN=0
TRUST_SCORE_MAX=100

# Rating Configuration
RATING_MIN_STARS=1
RATING_MAX_STARS=5
REVIEW_MAX_LENGTH=500
RATING_EDIT_WINDOW_HOURS=24

# API Configuration
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Integration API Keys
REGISTRATION_SERVICE_URL=http://localhost:3000/api/v1
MODERATION_SERVICE_URL=http://localhost:3002/api/v1
